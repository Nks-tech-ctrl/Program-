//paging 
#include <stdio.h>

int main() {
    int memSize, pageSize, noPages, noFrames, logicalAddr;
    int pageTable[100];

    printf("Enter total memory size: ");
    scanf("%d", &memSize);
    printf("Enter page size: ");
    scanf("%d", &pageSize);

    noPages = memSize / pageSize;
    printf("The number of pages available: %d\n", noPages);

    printf("Enter the page table (enter frame number for each page):\n");
    for(int i = 0; i < noPages; i++) {
        printf("Page %d: ", i);
        scanf("%d", &pageTable[i]);
    }

    printf("\nEnter logical address to find physical address: ");
    scanf("%d", &logicalAddr);

    int pageNum = logicalAddr / pageSize;
    int offset = logicalAddr % pageSize;

    if(pageNum >= noPages) {
        printf("Invalid Logical Address!\n");
    } else {
        int physicalAddr = (pageTable[pageNum] * pageSize) + offset;
        printf("Physical Address: %d\n", physicalAddr);
    }

    return 0;
}
