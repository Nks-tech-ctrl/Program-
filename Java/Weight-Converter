import java.util.Scanner;

public class WeightConverter {
    public static void main(String args[]) {
        Scanner sc = new Scanner(System.in);
        double weight;
        double newWeight;

        int choice;

        System.out.println("==========Weight conversion Program==========");
        System.out.println("1. Convert lbs to kgs");
        System.out.println("2. Converty kgs to lbs");

        System.out.println("Choose Option!");
        choice = sc.nextInt();

        if (choice == 1) {
            System.out.println("Enter the weight in lbs:");
            weight = sc.nextDouble();
            newWeight = weight * 0.453592;
            System.out.println("THe new weights in kgs is:" + newWeight);
        } else if (choice == 2) {
            System.out.println("Enter weights in kgs:");
            weight = sc.nextDouble();
            newWeight = weight * 2.204623;
            System.out.println("THe new weights in Lbs is:" + newWeight);
        }else{
            System.out.println("Invalid Choice!");
        }

        sc.close();
    }
}
